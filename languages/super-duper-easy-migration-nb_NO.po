#. Plugin Name of the plugin
msgid "Super Duper Easy Migration"
msgstr "Super Duper Easy Migration"

#. Description of the plugin
msgid "Migrate a WordPress site to another server via SSH and rsync — directly from the admin panel."
msgstr "Migrer et WordPress-nettsted til en annen server via SSH og rsync – direkte fra adminpanelet."

#: super-duper-easy-migration.php
msgid "%1$s requires the %2$s PHP function to be enabled. Please contact your hosting provider."
msgstr "%1$s krever at PHP-funksjonen %2$s er aktivert. Kontakt hostingleverandøren din."

#: super-duper-easy-migration.php
msgid "Migrate Site"
msgstr "Migrer nettsted"

#: super-duper-easy-migration.php
msgid "No access."
msgstr "Ingen tilgang."

#: super-duper-easy-migration.php
msgid "Pre-flight check"
msgstr "Forhåndssjekk"

#: super-duper-easy-migration.php
msgid "Database dump"
msgstr "Database-dump"

#: super-duper-easy-migration.php
msgid "File transfer"
msgstr "Filoverføring"

#: super-duper-easy-migration.php
msgid ".htaccess cleanup"
msgstr ".htaccess-opprydding"

#: super-duper-easy-migration.php
msgid "wp-config"
msgstr "wp-config"

#: super-duper-easy-migration.php
msgid "Database import"
msgstr "Database-import"

#: super-duper-easy-migration.php
msgid "Search & replace"
msgstr "Søk og erstatt"

#: super-duper-easy-migration.php
msgid "Cleanup"
msgstr "Opprydding"

#: super-duper-easy-migration.php
msgid "Migrate this WordPress site to another server via SSH and rsync."
msgstr "Migrer dette WordPress-nettstedet til en annen server via SSH og rsync."

#: super-duper-easy-migration.php
msgid "This site (source)"
msgstr "Denne siden (kilde)"

#: super-duper-easy-migration.php
msgid "Path:"
msgstr "Sti:"

